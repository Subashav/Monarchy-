<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Services | MONARCHY</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
    <header id="header">
        <div class="container-wide nav">
            <a href="/index.html" class="logo">
                <img src="/logo.png" alt="Monarchy Logo">
            </a>
            <div class="nav-right" style="display: flex; align-items: center; gap: 4rem;">
                <ul class="nav-links">
                    <li><a href="/index.html">Home</a></li>
                    <li class="nav-item-dropdown">
                        <a href="/services.html" class="active dropdown-toggle">Services <i data-lucide="chevron-down" style="width: 14px; height: 14px;"></i></a>
                        <div class="dropdown-menu">
                            <a href="/it-services.html" class="dropdown-item">
                                <i data-lucide="layers"></i>
                                <div class="dropdown-content">
                                    <h5>IT Services</h5>
                                    <p>Engineering and Enterprise Solutions</p>
                                </div>
                            </a>
                            <a href="/digital-marketing.html" class="dropdown-item">
                                <i data-lucide="megaphone"></i>
                                <div class="dropdown-content">
                                    <h5>Digital Marketing</h5>
                                    <p>Performance & Media Growth</p>
                                </div>
                            </a>
                            <a href="/hr-services.html" class="dropdown-item">
                                <i data-lucide="users"></i>
                                <div class="dropdown-content">
                                    <h5>HR Solutions</h5>
                                    <p>Talent Acquisition & Staffing</p>
                                </div>
                            </a>
                        </div>
                    </li>
                    <li><a href="/training.html">Training</a></li>
                    <li><a href="/about.html">About</a></li>
                    <li><a href="/contact.html">Contact</a></li>
                </ul>
                <div class="nav-actions">
                    <a href="/contact.html" class="btn btn-primary">Book Consultation</a>
                </div>
                <div class="mobile-toggle">
                    <i data-lucide="menu"></i>
                </div>
            </div>
        </div>
    </header>

    <main>
        <section id="services-hero" class="hero">
            <div class="hero-visual">
                <img src="/services-hero.png" alt="" style="position: absolute; width: 100%; height: 100%; opacity: 0.1; filter: blur(50px); pointer-events: none;">
                <canvas id="hero-galaxy" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;"></canvas>
            </div>
            <div class="container hero-content">
                <img src="/src/assets/hero-section.png" alt="Monarchy Branding" class="reveal" style="max-width: 320px; margin-bottom: 2rem; opacity: 0.8;">
                <h1 class="reveal">Built for<br><span class="gradient-text">Future.</span></h1>
                <p class="reveal">Monarchy is built on a simple idea: Growth for everyone. Whether it is a business looking to scale or an individual looking to start a career, we provide the right support, tools, and opportunities.</p>
            </div>
        </section>

        <section id="detailed-services" style="padding: 10rem 0;">
            <div class="container">
                <div class="section-header reveal" style="margin-bottom: 5rem; text-align: center;">
                    <h2 style="font-size: 2.5rem;">Total <span class="gradient-text">Dominance.</span></h2>
                    <p style="color: var(--text-secondary); margin-top: 1rem; font-size: 0.95rem; max-width: 600px; margin-left: auto; margin-right: auto;">We provide full-spectrum business services engineered to drive revenue, streamline operations, and position your brand for long-term market leadership.</p>
                </div>
                
                <div class="stacking-container">
                    <!-- IT Services Section -->
                    <div class="stack-card glass glow-card reveal">
                        <div class="service-row">
                            <div class="service-text">
                                <h3 style="font-size: 2.2rem; margin-bottom: 1rem;">Software & Tech <span class="gradient-text">Engineering</span></h3>
                                <p style="color: var(--text-secondary); margin-bottom: 2rem; line-height: 1.6;">We build high-performance software powered by modern architecture. From web systems to AI automation, we cover full-lifecycle engineering.</p>
                                
                                <div class="granular-services">
                                    <div class="gran-group">
                                        <h4><i data-lucide="monitor"></i> Web Development</h4>
                                        <ul>
                                            <li>Frontend Development (React/Next.js)</li>
                                            <li>Backend & API Engineering</li>
                                            <li>Fullstack Systems</li>
                                            <li>CMS & E-commerce</li>
                                        </ul>
                                    </div>
                                    <div class="gran-group">
                                        <h4><i data-lucide="smartphone"></i> Mobile Apps</h4>
                                        <ul>
                                            <li>Android App Development</li>
                                            <li>iOS App Development</li>
                                            <li>Flutter & React Native</li>
                                        </ul>
                                    </div>
                                    <div class="gran-group">
                                        <h4><i data-lucide="figma"></i> Design & UX</h4>
                                        <ul>
                                            <li>UI/UX Research</li>
                                            <li>Interactive Prototypes</li>
                                            <li>Visual Interface Design</li>
                                        </ul>
                                    </div>
                                    <div class="gran-group">
                                        <h4><i data-lucide="database"></i> Enterprise Tools</h4>
                                        <ul>
                                            <li>Custom ERP Systems</li>
                                            <li>CRM Solutions</li>
                                            <li>HRM Platforms</li>
                                        </ul>
                                    </div>
                                    <div class="gran-group">
                                        <h4><i data-lucide="brain-circuit"></i> AI & ML</h4>
                                        <ul>
                                            <li>Machine Learning (ML)</li>
                                            <li>Deep Learning (DL)</li>
                                            <li>Natural Language (NLP)</li>
                                            <li>Smart AI Chatbots</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div class="service-img-wrapper">
                                <img src="/it-services.png" alt="IT Services">
                            </div>
                        </div>
                    </div>

                    <!-- Digital Marketing Section -->
                    <div class="stack-card glass glow-card reveal">
                        <div class="service-row service-reverse">
                            <div class="service-img-wrapper">
                                <img src="/digital-marketing.png" alt="Digital Marketing">
                            </div>
                            <div class="service-text">
                                <h3 style="font-size: 2.2rem; margin-bottom: 1rem;">Online <span class="gradient-text">Marketing</span></h3>
                                <p style="color: var(--text-secondary); margin-bottom: 2rem; line-height: 1.6;">Grow your brand with data-backed marketing. We handle everything from rankings to creative content and ad management.</p>
                                
                                <div class="granular-services">
                                    <div class="gran-group">
                                        <h4><i data-lucide="search"></i> SEO & Organic</h4>
                                        <ul>
                                            <li>Technical SEO Audit</li>
                                            <li>On-Page & Off-Page SEO</li>
                                            <li>Keyword Strategy</li>
                                        </ul>
                                    </div>
                                    <div class="gran-group">
                                        <h4><i data-lucide="share-2"></i> Social Media</h4>
                                        <ul>
                                            <li>Social Media Marketing (SMM)</li>
                                            <li>Social Media Handling</li>
                                            <li>Growth Strategies</li>
                                        </ul>
                                    </div>
                                    <div class="gran-group">
                                        <h4><i data-lucide="trending-up"></i> Ads & Performance</h4>
                                        <ul>
                                            <li>PPC / Google Ads</li>
                                            <li>Performance Marketing</li>
                                            <li>ROI Tracking</li>
                                        </ul>
                                    </div>
                                    <div class="gran-group">
                                        <h4><i data-lucide="palette"></i> Creative & Content</h4>
                                        <ul>
                                            <li>Content Creation</li>
                                            <li>Professional Graphic Design</li>
                                            <li>Video Production</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- HR Solutions Section -->
                    <div class="stack-card glass glow-card reveal">
                        <div class="service-row">
                            <div class="service-text">
                                <h3 style="font-size: 2.2rem; margin-bottom: 1rem;">Hiring & <span class="gradient-text">HR Solutions</span></h3>
                                <p style="color: var(--text-secondary); margin-bottom: 2rem; line-height: 1.6;">Build and manage a better workforce. We help you find top talent and handle all legal and salary paperwork.</p>
                                
                                <div class="granular-services">
                                    <div class="gran-group">
                                        <h4><i data-lucide="users"></i> Talent Search</h4>
                                        <ul>
                                            <li>Executive Recruitment</li>
                                            <li>Staffing Solutions</li>
                                            <li>Direct Placement</li>
                                        </ul>
                                    </div>
                                    <div class="gran-group">
                                        <h4><i data-lucide="file-text"></i> Operations</h4>
                                        <ul>
                                            <li>Payroll Processing</li>
                                            <li>Statutory Compliance</li>
                                            <li>Legal Support</li>
                                        </ul>
                                    </div>
                                    <div class="gran-group">
                                        <h4><i data-lucide="briefcase"></i> Consulting</h4>
                                        <ul>
                                            <li>HR Strategy</li>
                                            <li>Employee Mentorship</li>
                                            <li>Retention Programs</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div class="service-img-wrapper">
                                <img src="/hr-services.png" alt="HR Services">
                            </div>
                        </div>
                    </div>
                </div>
                </div>
            </div>
        </section>

        <section id="cta" style="padding: 8rem 0; background: radial-gradient(circle at center, rgba(255, 255, 255, 0.05) 0%, transparent 70%);">
            <div class="container text-center reveal">
                <h2 style="font-size: 2.8rem; line-height: 1.15;">Ready to <br><span class="gradient-text">Scale?</span></h2>
                <p style="color: var(--text-secondary); margin-top: 1.5rem; font-size: 0.95rem; max-width: 500px; margin-left: auto; margin-right: auto;">Partner with Monarchy to unlock your full potential. From technology and marketing to HR and training, we have the expertise to take your business to the next level.</p>
                <div style="margin-top: 3rem;">
                    <a href="/contact.html" class="btn btn-primary" style="padding: 1rem 3rem; border-radius: 99px;">Start the Journey</a>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="container footer-content">
            <div class="footer-brand">
                <a href="/index.html" class="logo">
                    <img src="/logo.png" alt="Monarchy Logo">
                </a>
                <p>Empowering talent and accelerating business growth through expert IT, marketing, and HR solutions.</p>
                <div class="footer-socials">
                    <a href="https://instagram.com/monarchy" target="_blank" title="Instagram"><img src="https://cdn.jsdelivr.net/npm/simple-icons@v11/icons/instagram.svg" width="18" height="18" style="filter: invert(1);"></a>
                    <a href="https://linkedin.com/company/monarchy" target="_blank" title="LinkedIn"><img src="https://cdn.jsdelivr.net/npm/simple-icons@v11/icons/linkedin.svg" width="18" height="18" style="filter: invert(1);"></a>
                    <a href="https://x.com/monarchy" target="_blank" title="X"><img src="https://cdn.jsdelivr.net/npm/simple-icons@v11/icons/x.svg" width="18" height="18" style="filter: invert(1);"></a>
                </div>
            </div>
                <div class="link-group">
                    <h4>PAGES</h4>
                    <ul>
                        <li><a href="/index.html">Home</a></li>
                        <li><a href="/services.html">Services</a></li>
                        <li><a href="/training.html">Training</a></li>
                        <li><a href="/about.html">About</a></li>
                        <li><a href="/contact.html">Contact</a></li>
                    </ul>
                </div>
                <div class="link-group">
                    <h4>SERVICES</h4>
                    <ul>
                        <li><a href="/it-services.html">IT Services</a></li>
                        <li><a href="/digital-marketing.html">Digital Marketing</a></li>
                        <li><a href="/hr-services.html">HR Solutions</a></li>
                    </ul>
                </div>
                <div class="link-group">
                    <h4>CONTACT</h4>
                    <ul>
                        <li><i data-lucide="map-pin" size="14"></i> <span style="font-size: 0.85rem; opacity: 0.6;">Your Address, India</span></li>
                        <li><i data-lucide="phone" size="14"></i> <a href="tel:+910000000000">+91 Your Phone</a></li>
                        <li><i data-lucide="mail" size="14"></i> <a href="mailto:contact@monarchy.com">contact@monarchy.com</a></li>
                    </ul>
                </div>
        </div>
        <div class="container footer-bottom">
            <div class="footer-copyright">&copy; 2026 MONARCHY. ALL RIGHTS RESERVED.</div>
            <div class="footer-legal">
                <a href="#">Privacy Policy</a>
                <a href="#">Terms & Conditions</a>
            </div>
        </div>
    </footer>

    <script type="module" src="/src/main.js"></script>
</body>
</html>
